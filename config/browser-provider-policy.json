{
  "schema_version": 1,
  "providers": {
    "webwright": {
      "kind": "high-level-browser-workflow",
      "mcp": false
    },
    "playwright-cli": {
      "kind": "low-level-browser-automation",
      "mcp": false,
      "version": "0.1.14"
    },
    "chrome-devtools-mcp": {
      "kind": "devtools-debugging",
      "mcp": true,
      "version": "1.2.0"
    }
  },
  "routing": {
    "long_horizon_web_task": "webwright",
    "screenshots_snapshots_traces": "playwright-cli",
    "console_network_performance_memory_lighthouse": "chrome-devtools-mcp"
  },
  "forbidden_active_providers": [
    "playwright-mcp",
    "@playwright/mcp",
    "semgrep",
    "semgrep-mcp"
  ],
  "gemini_builtin_browser_agent": {
    "enabled": false,
    "reason": "This adapter release keeps the canonical provider matrix as Webwright, Playwright CLI, and Chrome DevTools MCP. Gemini built-in browser_agent is not enabled until separately modeled and validated.",
    "must_not_replace": [
      "webwright",
      "playwright-cli",
      "chrome-devtools-mcp"
    ]
  }
}
